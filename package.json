{
  "name": "flutter-cli-assistant",
  "displayName": "Flutter CLI Assistant",
  "description": "A powerful GUI, live console, and intelligent error analyzer for Flutter developers.",
  "version": "1.1.0",
  "publisher": "MuhammadThanseer",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/thanseer02/flutter-cli_vs_code_extn"
  },
  "keywords": [
    "flutter",
    "dart",
    "cli",
    "build",
    "tools",
    "android",
    "ios"
  ],
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Linters",
    "Programming Languages"
  ],
  "activationEvents": [
    "workspaceContains:pubspec.yaml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "flutter-cli-assistant.helloWorld",
        "title": "Flutter CLI: Hello World"
      },
      {
        "command": "flutter-cli-assistant.clearLogs",
        "title": "Flutter CLI: Clear Output Logs",
        "icon": "$(trash)"
      },
      {
        "command": "flutter-cli-assistant.exportLogs",
        "title": "Flutter CLI: Export Output Logs",
        "icon": "$(save)"
      },
      {
        "command": "flutter-cli-assistant.showDashboard",
        "title": "Flutter Assistant: Show Dashboard",
        "icon": "$(dashboard)"
      },
      {
        "command": "flutter-cli-assistant.run",
        "title": "Flutter: Run"
      },
      {
        "command": "flutter-cli-assistant.buildApk",
        "title": "Flutter: Build APK"
      },
      {
        "command": "flutter-cli-assistant.buildIpa",
        "title": "Flutter: Build IPA",
        "when": "isMac"
      },
      {
        "command": "flutter-cli-assistant.buildAppBundle",
        "title": "Flutter: Build AppBundle"
      },
      {
        "command": "flutter-cli-assistant.flutterClean",
        "title": "Flutter: Clean"
      },
      {
        "command": "flutter-cli-assistant.doctor",
        "title": "Flutter: Doctor"
      },
      {
        "command": "flutter-cli-assistant.showLogs",
        "title": "Flutter: Show Logs"
      },
      {
        "command": "flutter-cli-assistant.generateJsonSerializable",
        "title": "Flutter: Generate JSON Serializable"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "flutter-cli-assistant-explorer",
          "title": "Flutter Assistant",
          "icon": "$(terminal)"
        }
      ]
    },
    "views": {
      "flutter-cli-assistant-explorer": [
        {
          "id": "flutter-cli-assistant.projectDashboard",
          "name": "Project",
          "when": "flutter-cli-assistant.isFlutterProject"
        },
        {
          "id": "flutter-cli-assistant.sidebar",
          "name": "Commands",
          "when": "flutter-cli-assistant.isFlutterProject"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "flutter-cli-assistant.clearLogs",
          "when": "view == flutter-cli-assistant.sidebar",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Flutter CLI Assistant",
      "properties": {
        "flutter-cli-assistant.flutterSdkPath": {
          "type": "string",
          "default": "",
          "description": "Custom absolute path to the Flutter SDK."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "chai": "^6.2.2",
    "mocha": "^11.7.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "tree-kill": "^1.2.2"
  }
}
