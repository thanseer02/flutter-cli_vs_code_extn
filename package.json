{
  "name": "flutter-cli-assistant",
  "displayName": "Flutter CLI Assistant",
  "description": "One-click access to common Flutter commands, intelligent diagnostics, live logs, and AI-powered error explanations.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "flutter-cli-assistant.helloWorld",
        "title": "Flutter CLI: Hello World"
      },
      {
        "command": "flutter-cli-assistant.clearLogs",
        "title": "Flutter CLI: Clear Output Logs",
        "icon": "$(trash)"
      },
      {
        "command": "flutter-cli-assistant.exportLogs",
        "title": "Flutter CLI: Export Output Logs",
        "icon": "$(save)"
      },
      {
        "command": "flutter-cli-assistant.run",
        "title": "Flutter: Run"
      },
      {
        "command": "flutter-cli-assistant.buildApk",
        "title": "Flutter: Build APK"
      },
      {
        "command": "flutter-cli-assistant.buildAppBundle",
        "title": "Flutter: Build AppBundle"
      },
      {
        "command": "flutter-cli-assistant.buildWeb",
        "title": "Flutter: Build Web"
      },
      {
        "command": "flutter-cli-assistant.flutterClean",
        "title": "Flutter: Clean"
      },
      {
        "command": "flutter-cli-assistant.pubGet",
        "title": "Flutter: Pub Get"
      },
      {
        "command": "flutter-cli-assistant.pubUpgrade",
        "title": "Flutter: Pub Upgrade"
      },
      {
        "command": "flutter-cli-assistant.doctor",
        "title": "Flutter: Doctor"
      },
      {
        "command": "flutter-cli-assistant.devices",
        "title": "Flutter: Devices"
      },
      {
        "command": "flutter-cli-assistant.showLogs",
        "title": "Flutter: Show Logs"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "flutter-cli-assistant-explorer",
          "title": "Flutter Assistant",
          "icon": "$(terminal)"
        }
      ]
    },
    "views": {
      "flutter-cli-assistant-explorer": [
        {
          "id": "flutter-cli-assistant.sidebar",
          "name": "Commands",
          "when": "flutter-cli-assistant.isFlutterProject"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "flutter-cli-assistant.clearLogs",
          "when": "view == flutter-cli-assistant.sidebar",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "typescript": "^5.1.3"
  }
}
